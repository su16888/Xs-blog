# ========================================
# Xs-Blog 前端环境变量配置示例
# ========================================
# 复制此文件为 .env.local（开发环境）或 .env.production（生产环境）

# 前端服务端口（默认 3000）
PORT=3000

# ========================================
# API 地址配置
# ========================================
# 配置后端 API 地址，修改后需要重新构建前端：npm run build
#
# 示例：
# NEXT_PUBLIC_API_URL=http://localhost:3001/api          # 开发环境
# NEXT_PUBLIC_API_URL=http://your-server-ip:3001/api     # 生产环境
# NEXT_PUBLIC_API_URL=/api                               # Nginx 反向代理
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# ========================================
# 后台管理页面路径配置（重要！）
# ========================================
# 自定义后台入口路径，默认为 'admins'
#
# 安全建议：
# 1. 使用难以猜测的路径名（如：control-panel-xyz-2025）
# 2. 避免使用常见词汇（如：admin、manage、backend）
# 3. 定期更换后台路径
# 4. 配合强密码、登录限制等措施使用
#
# 注意事项：
# - 修改后需要重新构建前端才能生效
NEXT_PUBLIC_ADMIN_PATH=admins
